<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>متجر الألعاب الخاص بي</title>
    <style>
        body { font-family: sans-serif; text-align: center; background: #f4f4f4; padding: 20px; }
        h1 { color: #333; }
        #points-display { font-size: 20px; margin-bottom: 20px; font-weight: bold; }
        .game-card { 
            display: inline-block; width: 140px; margin: 10px; padding: 20px; 
            background: white; border-radius: 10px; cursor: pointer; transition: 0.3s;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .locked { background: #ccc; cursor: not-allowed; }
        .unlocked { background: #4CAF50; color: white; }
        .game-card:hover { transform: scale(1.05); }
    </style>
</head>
<body>

    <h1>متجر الألعاب</h1>
    <div id="points-display">رصيدك: <span id="points">100</span> نقطة</div>
    <div id="game-list"></div>

    <script>
        let userPoints = 100;
        // قائمة الـ 15 لعبة
        const games = [
            { id: 1, name: "Tap Mania", unlocked: true, cost: 0 },
            { id: 2, name: "Color Catch", unlocked: true, cost: 0 },
            { id: 3, name: "Quick Math", unlocked: true, cost: 0 },
            { id: 4, name: "Bubble Pop", unlocked: true, cost: 0 },
            { id: 5, name: "Memory Flip", unlocked: true, cost: 0 },
            { id: 6, name: "Stack It", unlocked: false, cost: 50 },
            { id: 7, name: "Perfect Toss", unlocked: false, cost: 70 },
            { id: 8, name: "Ball Balance", unlocked: false, cost: 80 },
            { id: 9, name: "Drop Shot", unlocked: false, cost: 90 },
            { id: 10, name: "Slide Puzzle", unlocked: false, cost: 100 },
            { id: 11, name: "Reflex Wall", unlocked: false, cost: 110 },
            { id: 12, name: "Logic Path", unlocked: false, cost: 120 },
            { id: 13, name: "Find the Odd", unlocked: false, cost: 130 },
            { id: 14, name: "Word Scramble", unlocked: false, cost: 140 },
            { id: 15, name: "Pattern Match", unlocked: false, cost: 150 }
        ];

        function renderGames() {
            const list = document.getElementById('game-list');
            list.innerHTML = '';
            games.forEach(game => {
                const div = document.createElement('div');
                div.className = `game-card ${game.unlocked ? 'unlocked' : 'locked'}`;
                div.innerHTML = `<h3>${game.name}</h3><p>${game.unlocked ? 'متاح للعب' : 'السعر: ' + game.cost}</p>`;
                div.onclick = () => buyGame(game.id);
                list.appendChild(div);
            });
        }

        function buyGame(id) {
            const game = games.find(g => g.id === id);
            if (!game.unlocked) {
                if (userPoints >= game.cost) {
                    userPoints -= game.cost;
                    game.unlocked = true;
                    document.getElementById('points').innerText = userPoints;
                    renderGames();
                } else {
                    alert("نقاطك غير كافية لفتح هذه اللعبة!");
                }
            } else {
                alert("هذه اللعبة متاحة بالفعل، استمتع باللعب!");
            }
        }

        renderGames();
    </script>
</body>
</html>
